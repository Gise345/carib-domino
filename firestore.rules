rules_version = '2';

// Default-deny baseline.
//
// Every Firestore collection in this project must be explicitly allowed below.
// Until a collection has its own rule, all client reads and writes are denied.
//
// Trust model reminder (see docs/ARCHITECTURE.md §4):
//   - Wallets, ELO, stats, entitlements, match results: writes ONLY via Cloud
//     Functions using the Admin SDK (which bypasses these rules). Clients may
//     read their own where applicable; never write.
//   - Per-user documents: ownership checked against `request.auth.uid`, never
//     against fields stored in the document.
//   - Add a per-collection match block for every new collection introduced.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
