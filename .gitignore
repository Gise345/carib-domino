# =============================================================================
# Unity
# =============================================================================
unity/[Ll]ibrary/
unity/[Tt]emp/
unity/[Oo]bj/
unity/[Bb]uild/
unity/[Bb]uilds/
unity/[Ll]ogs/
unity/[Uu]ser[Ss]ettings/
unity/[Mm]emoryCaptures/
unity/[Rr]ecordings/

# Note: do NOT ignore *.meta files under Assets/. Unity needs them tracked
# alongside their corresponding assets — losing them breaks references.

# Uncomment this line if you wish to ignore the asset store tools plugin
# unity/[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
unity/[Aa]ssets/Plugins/Editor/JetBrains*

# Photon Fusion 2 sample bundles — vendored .unitypackage files we don't
# import. Skipping them keeps the repo ~15MB smaller; they can be
# re-downloaded from the Photon SDK at any time if needed.
unity/[Aa]ssets/Photon/FusionDemos/*.unitypackage*
unity/[Aa]ssets/Photon/FusionMenu/*.unitypackage*

# Firebase Unity SDK macOS/Linux native libs for the App core — both exceed
# GitHub's 100 MB-per-file hard limit (.bundle ≈ 191 MB, .so ≈ 123 MB on
# the 13.10 SDK). We're Windows-only for current dev; the Windows .dll
# (16 MB) is kept. macOS/iOS/Linux build machines re-vendor the SDK at
# build time to pull these files in (or switch to Git LFS at that point).
unity/[Aa]ssets/Firebase/Plugins/x86_64/FirebaseCppApp-*.bundle
unity/[Aa]ssets/Firebase/Plugins/x86_64/FirebaseCppApp-*.so

# Visual Studio cache directory
.vs/

# Unity-generated solution/project files (regenerated by Unity)
unity/*.csproj
unity/*.unityproj
unity/*.sln
unity/*.suo
unity/*.tmp
unity/*.user
unity/*.userprefs
unity/*.pidb
unity/*.booproj
unity/*.svd
unity/*.pdb
unity/*.mdb
unity/*.opendb
unity/*.VC.db

# Unity3D generated meta files
unity/*.pidb.meta
unity/*.pdb.meta
unity/*.mdb.meta

# Unity3D generated file on crash reports
unity/sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
unity/crashlytics-build.properties

# Packed Addressables
unity/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
unity/[Aa]ssets/[Ss]treamingAssets/aa.meta
unity/[Aa]ssets/[Ss]treamingAssets/aa/*

