# Reference template for .env. Copy this file to `.env` and populate the
# values from Firebase Console → Project settings → Your apps → Web app.
# `.env` is gitignored; this file is committed so future contributors know
# which variables are expected.
#
# Note: the Firebase Web apiKey is NOT a secret in the strict sense (it's
# delivered to every client and identifies the project rather than
# authenticating it). Security is enforced by Firestore/Storage rules,
# Auth provider configuration, and App Check. We env-isolate these values
# anyway for project-swap flexibility and to normalise where future *genuine*
# secrets (RevenueCat webhook shared secret, Photon master-server secret,
# service-account JSON paths) will live.

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=
